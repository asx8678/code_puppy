{
  "_metadata": {
    "description": "Turbo Parse Performance Baseline",
    "created": "2025-01-07",
    "platform": "Apple M1 MacBook Pro",
    "notes": "Target goals for cold parse - measured without cache",
    "target_goals": {
      "python_parse/1k_loc/cold_parse": "< 5ms",
      "python_parse/10k_loc/cold_parse": "< 30ms",
      "python_parse/100k_loc/cold_parse": "< 250ms",
      "rust_parse/1k_loc/cold_parse": "< 5ms",
      "rust_parse/10k_loc/cold_parse": "< 30ms",
      "rust_parse/100k_loc/cold_parse": "< 250ms",
      "javascript_parse/1k_loc/cold_parse": "< 5ms",
      "javascript_parse/10k_loc/cold_parse": "< 30ms",
      "javascript_parse/100k_loc/cold_parse": "< 250ms"
    }
  },
  "benchmarks": [
    {
      "name": "python_parse/1k_loc/cold_parse",
      "duration_ns": 5000000,
      "target_ms": 5,
      "note": "Target: 1k Python LOC under 5ms"
    },
    {
      "name": "python_parse/10k_loc/cold_parse",
      "duration_ns": 30000000,
      "target_ms": 30,
      "note": "Target: 10k Python LOC under 30ms"
    },
    {
      "name": "python_parse/100k_loc/cold_parse",
      "duration_ns": 250000000,
      "target_ms": 250,
      "note": "Target: 100k Python LOC under 250ms"
    },
    {
      "name": "rust_parse/1k_loc/cold_parse",
      "duration_ns": 5000000,
      "target_ms": 5,
      "note": "Target: 1k Rust LOC under 5ms"
    },
    {
      "name": "rust_parse/10k_loc/cold_parse",
      "duration_ns": 30000000,
      "target_ms": 30,
      "note": "Target: 10k Rust LOC under 30ms"
    },
    {
      "name": "rust_parse/100k_loc/cold_parse",
      "duration_ns": 250000000,
      "target_ms": 250,
      "note": "Target: 100k Rust LOC under 250ms"
    },
    {
      "name": "javascript_parse/1k_loc/cold_parse",
      "duration_ns": 5000000,
      "target_ms": 5,
      "note": "Target: 1k JavaScript LOC under 5ms"
    },
    {
      "name": "javascript_parse/10k_loc/cold_parse",
      "duration_ns": 30000000,
      "target_ms": 30,
      "note": "Target: 10k JavaScript LOC under 30ms"
    },
    {
      "name": "javascript_parse/100k_loc/cold_parse",
      "duration_ns": 250000000,
      "target_ms": 250,
      "note": "Target: 100k JavaScript LOC under 250ms"
    }
  ]
}
