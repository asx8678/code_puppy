<%!-- 
  Test fixture: heex_template.heex
  Purpose: HEEx (HTML+EEx) template syntax - KNOWN GAP
  
  HEEx templates embed Elixir expressions in HTML and are compiled by Phoenix.
  The tree-sitter-elixir grammar may not fully support HEEx-specific syntax.
  
  Expected symbols: Phoenix function components, slots, attributes
  Known gaps: HEEx sigils (~H), component syntax, slot definitions
--%>

<%!-- Regular EEx constructs should work --%>
<div class="container">
  <h1><%= @title %></h1>
  
  <%= if @user do %>
    <p>Welcome, <%= @user.name %>!</p>
  <% else %>
    <p>Please <a href="/login">sign in</a></p>
  <% end %>
</div>

<%!-- Phoenix component syntax - potential gap --%>
<.form let={f} for={@changeset} phx-submit="save">
  <.input field={f[:email]} type="email" label="Email" />
  <.input field={f[:password]} type="password" label="Password" />
  <.button>Save</.button>
</.form>

<%!-- Phoenix function component with slots - potential gap --%>
<.modal id="confirm-modal">
  <:title>Confirm Delete</:title>
  <:body>Are you sure you want to delete this?</:body>
  <:footer>
    <.button phx-click="cancel">Cancel</.button>
    <.button type="danger" phx-click="confirm">Delete</.button>
  </:footer>
</.modal>

<%!-- HEEx sigil syntax - LIKELY GAP, not standard .ex/.exs --%>
<%!-- In .ex/.exs files, this would be: ~H"""...""" --%>
