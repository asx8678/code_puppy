#!/usr/bin/env bash
# pup - Code Puppy CLI wrapper
# Delegates to the Elixir escript or falls back to the Python entry point.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
EScript="${SCRIPT_DIR}/../code_puppy_control"

# Prefer the escript if it exists
if command -v elixir &>/dev/null && [ -f "${EScript}" ]; then
    exec elixir "${EScript}" "$@"
fi

# Fall back to the Python `pup` if available
if command -v pup &>/dev/null; then
    exec pup "$@"
fi

echo "Error: Neither the Elixir escript nor the Python 'pup' command is available." >&2
exit 1
