#!/usr/bin/env bash
# code-puppy - Code Puppy CLI wrapper (full name alias)
# Delegates to the Elixir escript or falls back to the Python entry point.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
EScript="${SCRIPT_DIR}/../code_puppy_control"

# Prefer the escript if it exists
if command -v elixir &>/dev/null && [ -f "${EScript}" ]; then
    exec elixir "${EScript}" "$@"
fi

# Fall back to the Python `code-puppy` if available
if command -v code-puppy &>/dev/null; then
    exec code-puppy "$@"
fi

echo "Error: Neither the Elixir escript nor the Python 'code-puppy' command is available." >&2
exit 1
