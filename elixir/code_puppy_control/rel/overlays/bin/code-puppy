#!/bin/sh
# code-puppy - Code Puppy CLI wrapper (full name alias)
# Delegates to the Elixir escript in the release, or falls back to Python.
#
# NOTE: This wrapper is used by `mix release` output only.
# For Burrito single-binary distribution (bd-171), see docs/burrito-release.md —
# Burrito binaries are self-contained and do not use these overlays.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
RELEASE_DIR="${SCRIPT_DIR}/.."

# Try the release escript first (installed via overlay)
for escript in "${RELEASE_DIR}"/lib/code_puppy_control-*/priv/bin/code_puppy_control; do
    if [ -f "${escript}" ] && command -v elixir >/dev/null 2>&1; then
        exec elixir "${escript}" "$@"
    fi
done

# Fall back to the Python `code-puppy` if available
if command -v code-puppy >/dev/null 2>&1; then
    exec code-puppy "$@"
fi

echo "Error: Neither the Elixir escript nor the Python 'code-puppy' command is available." >&2
exit 1
